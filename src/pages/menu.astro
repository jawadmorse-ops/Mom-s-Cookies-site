---
import Layout from '../layouts/Layout.astro';
import MenuGrid from '../components/MenuGrid';
---

<Layout title="Menu — Mom's Cookies" description="Browse all our fresh-baked cookie flavors and add to your bundle.">
  <div class="pt-28 pb-16 px-6 min-h-screen">
    <div class="max-w-7xl mx-auto">
      <div class="mb-10">
        <p class="section-subtitle mb-2">Our Menu</p>
        <h1 class="section-title">Every Cookie We Make</h1>
        <p class="text-chocolate-500 mt-2 max-w-lg text-sm">
          Pick your favorites — bundle 6, 9, or 12 for the best prices.
        </p>
      </div>
      <MenuGrid client:load />
    </div>
  </div>
</Layout>
