<footer class="bg-chocolate-950 text-cream-200 py-16 mt-24">
  <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-10">
    <!-- Brand -->
    <div>
      <div class="flex items-center gap-2 mb-4">
        <span class="text-2xl">🍪</span>
        <span class="font-display font-bold text-xl text-cream-100">Crumble & Co.</span>
      </div>
      <p class="text-cream-300 text-sm leading-relaxed">
        Artisan cookies baked fresh daily with love, quality ingredients, and a whole lot of butter.
      </p>
    </div>

    <!-- Links -->
    <div>
      <h3 class="font-semibold text-cream-100 mb-4">Quick Links</h3>
      <ul class="flex flex-col gap-2 text-sm text-cream-300">
        <li><a href="/" class="hover:text-cookie-400 transition-colors">Home</a></li>
        <li><a href="/menu" class="hover:text-cookie-400 transition-colors">Our Menu</a></li>
        <li><a href="/order" class="hover:text-cookie-400 transition-colors">Place an Order</a></li>
      </ul>
    </div>

    <!-- Contact -->
    <div>
      <h3 class="font-semibold text-cream-100 mb-4">Get In Touch</h3>
      <ul class="flex flex-col gap-2 text-sm text-cream-300">
        <li>hello@crumbleandco.com</li>
        <li>Mon – Sat: 8am – 6pm</li>
        <li>Orders need 24hrs notice</li>
      </ul>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-6 mt-12 pt-6 border-t border-chocolate-800 text-center text-xs text-cream-400">
    &copy; {new Date().getFullYear()} Crumble & Co. All rights reserved.
  </div>
</footer>
